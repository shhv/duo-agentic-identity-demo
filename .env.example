# ─── Duo SSO / OAuth (from the MCP OIDC integration) ────────
# Found on the MCP OIDC integration page → General tab → OAuth Token URL
# Use the base URL without /token for AUTHORIZE, with /token for TOKEN
OAUTH_AUTHORIZE_URL=https://sso-xxxxxxxx.sso.duosecurity.com/oauth2/XXXXXXXXX/authorize
OAUTH_TOKEN_URL=https://sso-xxxxxxxx.sso.duosecurity.com/oauth2/XXXXXXXXX/token

# Client ID from the Confidential Client Registration section
OAUTH_CLIENT_ID=your-client-id-from-mcp-oidc-integration

# Scopes (openid is required)
OAUTH_SCOPE=openid

# Local port for OAuth callback (browser redirects here after login)
OAUTH_REDIRECT_PORT=8085

# ─── Duo agentgateway integration (Details section) ──────────
# From Applications → agentgateway integration → Details
DUO_API_HOSTNAME=api-xxxxxxxx.duosecurity.com
DUO_INTEGRATION_KEY=your-integration-key
# Secret key goes in ./gateway/secrets/duo_skey (file, not env var)

# ─── Container images ───────────────────────────────────────
AGENTGATEWAY_IMAGE=cr.agentgateway.dev/agentgateway:0.12.0
AUTHZ_CONNECTOR_IMAGE=duosecurity/authorization-connector:v1.0.0

# ─── Cloudflare Tunnel ──────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── Gateway URL (public tunnel URL for agents) ─────────────
# This is what clients connect to (your Cloudflare tunnel public URL + /mcp)
GATEWAY_URL=https://mcpgw.example.com/mcp
